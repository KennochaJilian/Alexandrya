PORT=4000
CORS_ORIGIN=http://localhost:4200
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB local, Docker ou Atlas.
MONGO_URI=mongodb://127.0.0.1:27017/alexandrya
MONGO_DB_NAME=alexandrya

# Dossier local synchronise par OneDrive contenant les ebooks.
EBOOK_ROOT=C:\Users\you\OneDrive\Ebooks

# Format attendu des noms de fichiers pour inferer les metadonnees.
# Valeurs possibles: title-author ou author-title.
EBOOK_FILENAME_PATTERN=title-author

# Recherche des couvertures via Google Books, puis Open Library en fallback.
COVER_LOOKUP_ENABLED=true
GOOGLE_BOOKS_API_KEY=
COVER_STORAGE_PATH=./data/covers
COVER_PUBLIC_PATH=/covers

# Recherche Typesense. MongoDB reste le fallback si TYPESENSE_ENABLED=false
# ou si le serveur Typesense n'est pas joignable.
TYPESENSE_ENABLED=false
TYPESENSE_HOST=127.0.0.1
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=xyz
TYPESENSE_COLLECTION=books

# SMTP utilise pour Send to Kindle. L'adresse FROM doit etre approuvee
# dans les preferences Amazon Kindle du destinataire.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-me
MAIL_FROM=mailer@example.com
