PORT=4000
CORS_ORIGIN=http://localhost:4200
JWT_SECRET=replace-with-a-long-random-secret

# MongoDB local, Docker ou Atlas.
MONGO_URI=mongodb://127.0.0.1:27017/alexandrya
MONGO_DB_NAME=alexandrya

# Dossier local synchronise par OneDrive contenant les ebooks.
EBOOK_ROOT=C:\Users\you\OneDrive\Ebooks

# Format attendu des noms de fichiers pour inférer les metadonnees.
# Valeurs possibles: title-author ou author-title.
EBOOK_FILENAME_PATTERN=title-author

# SMTP utilise pour Send to Kindle. L'adresse FROM doit etre approuvee
# dans les preferences Amazon Kindle du destinataire.
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=mailer@example.com
SMTP_PASS=replace-me
MAIL_FROM=mailer@example.com
