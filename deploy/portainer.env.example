ALEXANDRYA_API_IMAGE=registry.example.com/alexandrya-api:latest
API_HOST_PORT=4000
CORS_ORIGIN=https://alexandrya.aquarius.irish
LOG_LEVEL=info

JWT_SECRET=change-me-with-a-long-random-secret
TYPESENSE_API_KEY=change-me-with-a-long-random-secret
TYPESENSE_COLLECTION=books

ALEXANDRYA_LIBRARY_PATH=/srv/alexandrya/library
ALEXANDRYA_LIBRARY_GID=993
EBOOK_FILENAME_PATTERN=title-author
EBOOK_UPLOAD_SUBDIRECTORY=Uploads
UPLOAD_MAX_FILES=10
UPLOAD_MAX_FILE_SIZE_MB=80
LIBRARY_SCAN_CONCURRENCY=4

COVER_LOOKUP_ENABLED=true
COVER_LOOKUP_TIMEOUT_MS=4500
GOOGLE_BOOKS_API_KEY=

SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
